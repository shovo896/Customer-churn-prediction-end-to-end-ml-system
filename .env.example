# Copy this file to `.env` and fill in real values.
DAGSHUB_USERNAME=your_dagshub_username
DAGSHUB_REPO=your_repo_name
DAGSHUB_USER_TOKEN=your_dagshub_token
DAGSHUB_TOKEN=${DAGSHUB_USER_TOKEN}
MLFLOW_TRACKING_URI=https://dagshub.com/${DAGSHUB_USERNAME}/${DAGSHUB_REPO}.mlflow
MLFLOW_TRACKING_USERNAME=${DAGSHUB_USERNAME}
MLFLOW_TRACKING_PASSWORD=${DAGSHUB_USER_TOKEN}
